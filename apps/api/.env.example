# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://fortichain:fortichain_secret@localhost:5432/fortichain

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────
JWT_SECRET=change_me_to_64_random_chars
JWT_REFRESH_SECRET=change_me_to_another_64_random_chars
BCRYPT_ROUNDS=12

# ── Wallet Encryption ─────────────────────────
WALLET_ENCRYPTION_SECRET=change_me_to_32_random_chars

# ── GenLayer ──────────────────────────────────
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_CONTRACT_ADDRESS=                        # you fill after deploy
GENLAYER_PRIVATE_KEY=                             # fortichain server wallet

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=alerts@fortichain.io

# ── External Signal Feeds ─────────────────────
ETHERSCAN_API_KEY=
ALCHEMY_API_KEY=
FORTA_API_KEY=
COINGECKO_API_KEY=
TWITTER_BEARER_TOKEN=

# ── App ───────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:3001
